# Supabase — get these from your project's API settings page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5...

# Public site URL (used for invite/reset email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Login page: one-click seeded demo accounts + hero hint (hackathon / internal demos).
# Set to false for a production-style login (no demo card).
# Omit or true = show demo helpers (default).
# NEXT_PUBLIC_SHOW_DEMO_LOGINS=true
# NEXT_PUBLIC_SHOW_DEMO_LOGINS=false

# Optional — Resend email (Phase 10 stretch). App still works without it.
RESEND_API_KEY=
RESEND_FROM_EMAIL=AtomQuest <noreply@atomquest.example>

# Optional — Microsoft Teams Incoming Webhook for adaptive card notifications.
# When set, the app fans out submission/approval/escalation cards to that channel.
# Leave blank for local dev — every call is a graceful no-op.
TEAMS_WEBHOOK_URL=

# Optional — Azure AD / Entra group → role mapping for SSO sign-ins.
# Provide comma-separated Entra Group Object IDs. The Microsoft sign-in
# button on /login lights up automatically once Supabase Azure provider
# is configured; these vars only affect role resolution after callback.


